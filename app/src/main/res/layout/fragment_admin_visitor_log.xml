<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA"
    android:fitsSystemWindows="true">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbarLog"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/blue"
        app:title="Tüm Ziyaretçi Kayıtları"
        app:titleTextColor="@android:color/white"
        app:navigationIcon="@android:drawable/ic_menu_revert"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/layoutHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#E9ECEF"
        android:padding="12dp"
        app:layout_constraintTop_toBottomOf="@id/toolbarLog">

        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.2" android:text="Tarih" android:textStyle="bold" android:textSize="11sp"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="2" android:text="Ziyaretçi" android:textStyle="bold" android:textSize="11sp"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="2" android:text="Ziyaret Ettiği Kişi" android:textStyle="bold" android:textSize="11sp"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Durum" android:gravity="end" android:textStyle="bold" android:textSize="11sp"/>
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvVisitorLog"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/layoutHeader"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>